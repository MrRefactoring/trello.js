# Live test credentials — copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
#
# To obtain credentials:
#   API key:   https://trello.com/app-key
#   API token: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=YOUR_API_KEY

TRELLO_API_KEY=your_api_key_here
TRELLO_API_TOKEN=your_api_token_here
TRELLO_MEMBER2_ID=second_trello_member_id_here
TRELLO_MEMBER2_EMAIL=second_trello_member_email_here

# Optional — required only for enterprise live tests.
# Enterprise admin token must be used (not a regular user token).
TRELLO_ENTERPRISE_ID=your_enterprise_id_here

# Optional — required only for plugin live tests.
# Must be a Power-Up you own; find the ID in Trello Power-Up Admin.
TRELLO_PLUGIN_ID=your_plugin_id_here
